# Seeed XIAO EE02 Specifics
CONFIG_BOARD_DRIVER_SEEEDSTUDIO_XIAO_EE02=y

# Flash Configuration
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"

# Internal flash storage (LittleFS)
CONFIG_USE_INTERNAL_FLASH_STORAGE=y

# Console stays on the default UART0 (NOT USB-Serial-JTAG). Routing the console
# to USB-SJ froze the frame: the console TX blocks when a USB host holds the port
# open without draining it (frame USB-powered from a PC), stalling the render loop
# until the task watchdog resets the board — a rotate-then-reboot loop. Improv
# still provisions over USB-SJ, gated on the chip target in improv_serial.c,
# independent of the console.
