# Seeed XIAO EE02 Specifics
CONFIG_BOARD_DRIVER_SEEEDSTUDIO_XIAO_EE02=y

# Flash Configuration
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"

# Internal flash storage (LittleFS)
CONFIG_USE_INTERNAL_FLASH_STORAGE=y

# Route the console to the native USB-Serial-JTAG port (the same port used for
# flashing). This makes boot logs visible over the single USB cable and lets the
# browser flasher (ESP Web Tools) hand over Wi-Fi credentials via Improv-Serial.
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y
